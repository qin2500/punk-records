# Discord
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Database (Supabase — use the direct connection string, port 5432, not the pooled one)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# OMDB API key — free at https://www.omdbapi.com/apikey.aspx (1000 req/day)
# Without this, IMDb cards fall back to scraping IMDb directly (may not always work)
OMDB_API_KEY=

# API
PORT=3001
# API_URL is used by the bot to reach the API inside Docker (set in docker-compose, no need to set here)

# Cloudflare Tunnel (get token from dash.cloudflare.com → Zero Trust → Tunnels)
CLOUDFLARE_TUNNEL_TOKEN=
