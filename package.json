{
  "name": "punk-records",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=packages/api\" \"npm run dev --workspace=packages/web\"",
    "build": "npm run build --workspace=packages/shared && npm run build --workspace=packages/api && npm run build --workspace=packages/bot && npm run build --workspace=packages/web",
    "db:migrate": "npm run db:migrate --workspace=packages/shared",
    "db:generate": "npm run db:generate --workspace=packages/shared",
    "db:studio": "npm run db:studio --workspace=packages/shared"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  }
}
