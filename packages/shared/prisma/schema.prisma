generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Collage {
  id               String   @id @default(cuid())
  name             String
  discordChannelId String   @unique
  createdAt        DateTime @default(now())
  cards            Card[]
}

model Card {
  id               String     @id @default(cuid())
  collageId        String
  collage          Collage    @relation(fields: [collageId], references: [id], onDelete: Cascade)

  type             CardType
  content          String?
  notes            String?
  url              String?

  ogTitle          String?
  ogDescription    String?
  ogImage          String?
  ogSiteName       String?
  ogFavicon        String?

  x                Float      @default(0)
  y                Float      @default(0)
  width            Float      @default(280)
  height           Float      @default(160)

  source           CardSource
  discordMessageId String?

  createdAt        DateTime   @default(now())
}

enum CardType {
  LINK
  NOTE
  IMAGE
}

enum CardSource {
  DISCORD
  WEBAPP
}
